{
	"name": "smartdesk/debug-logger",
	"description": "Human-friendly WordPress debug logger with hook status block and optional rotating file sink.",
	"type": "library",
	"license": "GPL-3.0-or-later",
	"authors": [
		{ "name": "SmartDesk Development Team - Ing. M. Kronsteiner", "email": "debuglogger+login.kronsteiner@gmail.com" }
	],
	"keywords": ["wordpress", "logger", "debug", "hooks", "timers"],
	"require": {
		"php": ">=8.1"
	},
	"autoload": {
		"psr-4": {
			"SmartDesk\\Utils\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"SmartDesk\\Utils\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5",
		"phpstan/phpstan": "^2.1",
		"squizlabs/php_codesniffer": "^3.13"
	},
	"scripts": {
		"test": "php vendor/bin/phpunit --colors=always",
		"phpstan": "vendor/bin/phpstan analyse --no-progress",
		"phpcs": "vendor/bin/phpcs",
		"qa": [
		"@phpstan",
		"@phpcs",
		"@test"
		]
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"support": {
	"issues": "https://github.com/martin-kronsteiner/SmartDesk-DebugLogger/issues",
	"source": "https://github.com/martin-kronsteiner/SmartDesk-DebugLogger"
	}	
}
