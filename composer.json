{
	"name": "smartdesk/debuglogger",
	"description": "Lightweight PSR-4 debug logger with rotating files, WP integration helpers and timing utilities.",
	"type": "library",
	"license": "GPL-3.0-or-later",
	"authors": [
		{
			"name": "SmartDesk",
			"email": "support@kronsteiner.gmbh"
		}
	],
	"require": {
		"php": ">=8.1"
	},
	"autoload": {
		"psr-4": {
			"SmartDesk\\Debug\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"SmartDesk\\Debug\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"scripts": {
		"test": "phpunit"
	}
}
