{
	"name": "smartdesk/debug-logger",
	"description": "Human-friendly WordPress debug logger with hook status block and optional rotating file sink.",
	"type": "library",
	"license": "GPL-3.0-or-later",
	"authors": [
		{ "name": "SmartDesk Development Team" }
	],
	"require": {
		"php": ">=8.1"
	},
	"autoload": {
		"psr-4": {
			"SmartDesk\\Utils\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"SmartDesk\\Utils\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"scripts": {
		"test": "phpunit"
	}
}
